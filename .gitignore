# ──────────────────────────────────────────────
.terraform/
.terraform.lock.hcl
*.tfstate
*.tfstate.backup
*.tfstate.*.backup
*.tfvars
!*.tfvars.example
!github-ci.tfvars
!jenkins-ci.tfvars
crash.log
crash.*.log
terraform/bootstrap/backend.tf

